@page "/quick-entry"
@rendermode InteractiveServer
@inject LedgerService LedgerService

<PageTitle>快速记账</PageTitle>

<section class="entry-page">
    <section class="entry-card">
        <p class="section-tag">Quick Entry</p>
        <h2>3 秒记一笔</h2>
        <p class="text-muted">默认先服务“家庭日常支出”，把金额、分类、成员压缩成最少输入项。</p>

        @if (_context is null)
        {
            <p>正在加载记账上下文...</p>
        }
        else
        {
            <EditForm Model="_request" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    <div>
                        <label class="form-label">收支类型</label>
                        <InputSelect class="form-select" @bind-Value="_request.Kind">
                            <option value="@TransactionKind.Expense">支出</option>
                            <option value="@TransactionKind.Income">收入</option>
                        </InputSelect>
                    </div>

                    <div>
                        <label class="form-label">金额</label>
                        <InputNumber class="form-control" @bind-Value="_request.Amount" />
                    </div>

                    <div>
                        <label class="form-label">家庭成员</label>
                        <InputSelect class="form-select" @bind-Value="_request.MemberId">
                            @foreach (var member in _context.Members)
                            {
                                <option value="@member.Id">@member.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <label class="form-label">分类</label>
                        <InputSelect class="form-select" @bind-Value="_request.CategoryId">
                            @foreach (var category in FilteredCategories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <label class="form-label">商户/场景</label>
                        <InputText class="form-control" @bind-Value="_request.MerchantName" />
                    </div>

                    <div>
                        <label class="form-label">支付方式</label>
                        <InputSelect class="form-select" @bind-Value="_request.PaymentMethod">
                            @foreach (var method in _context.PaymentMethods)
                            {
                                <option value="@method">@method</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="full">
                        <label class="form-label">备注</label>
                        <InputText class="form-control" @bind-Value="_request.Note" />
                    </div>
                </div>

                <div class="quick-buttons">
                    <button class="btn btn-primary" type="submit">保存账单</button>
                    <button class="btn btn-outline-dark" type="button" @onclick="FillDinnerPreset">晚餐预设</button>
                    <button class="btn btn-outline-dark" type="button" @onclick="FillGroceriesPreset">买菜预设</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="alert alert-success status-banner">@_message</div>
                }
            </EditForm>
        }
    </section>

    <aside class="highlight-card">
        <p class="section-tag">Fast Lane</p>
        <h2>录入优化方向</h2>
        <div class="chip-grid">
            <span class="chip">默认支出</span>
            <span class="chip">常用分类置顶</span>
            <span class="chip">记住最近成员</span>
            <span class="chip">截图待确认转正式账单</span>
        </div>

        <ol class="guideline-list">
            <li>保持“金额 + 分类 + 成员”三步内完成录入。</li>
            <li>备注和商户信息允许后补，不阻塞保存。</li>
            <li>快捷指令上传的截图先落到收件箱，再确认转账单。</li>
        </ol>
    </aside>
</section>

@code {
    private QuickEntryContext? _context;
    private QuickEntryRequest _request = new();
    private string? _message;

    private IEnumerable<LedgerCategory> FilteredCategories =>
        _context?.Categories.Where(x => x.Kind == _request.Kind) ?? Enumerable.Empty<LedgerCategory>();

    protected override async Task OnInitializedAsync()
    {
        _context = await LedgerService.GetQuickEntryContextAsync();
        ResetRequest();
    }

    private async Task SaveAsync()
    {
        var transaction = await LedgerService.AddTransactionAsync(_request);
        _message = $"已记录 {transaction.CategoryName} {transaction.Amount:C}。";
        ResetRequest();
    }

    private void FillDinnerPreset()
    {
        if (_context is null)
        {
            return;
        }

        _request.Kind = TransactionKind.Expense;
        _request.CategoryId = _context.Categories.First(x => x.Name == "餐饮").Id;
        _request.MerchantName = "晚餐";
        _request.Note = "可直接改成具体餐厅";
    }

    private void FillGroceriesPreset()
    {
        if (_context is null)
        {
            return;
        }

        _request.Kind = TransactionKind.Expense;
        _request.CategoryId = _context.Categories.First(x => x.Name == "买菜").Id;
        _request.MerchantName = "超市/生鲜";
        _request.Note = "日常采购";
    }

    private void ResetRequest()
    {
        if (_context is null)
        {
            return;
        }

        var defaultCategory = _context.Categories.First(x => x.Kind == TransactionKind.Expense);
        _request = new QuickEntryRequest
        {
            Kind = TransactionKind.Expense,
            CategoryId = defaultCategory.Id,
            MemberId = _context.Members.First().Id,
            PaymentMethod = _context.PaymentMethods.First(),
            Amount = 0,
            MerchantName = string.Empty,
            Note = string.Empty
        };
    }
}

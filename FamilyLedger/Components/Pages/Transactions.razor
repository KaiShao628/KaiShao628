@page "/transactions"
@rendermode InteractiveServer
@inject LedgerService LedgerService

<PageTitle>账单流水</PageTitle>

<section class="transactions-page">
    <section class="table-card">
        <div class="table-tools">
            <div>
                <p class="section-tag">Transactions</p>
                <h2>账单流水</h2>
            </div>
            <div class="filters">
                <input class="form-control" type="month" value="@_selectedMonthText" @onchange="OnMonthChanged" />
                <button class="btn btn-outline-dark" @onclick="ReloadAsync">刷新</button>
            </div>
        </div>

        @if (_items is null)
        {
            <p>正在加载账单...</p>
        }
        else
        {
            <table class="ledger-table">
                <thead>
                    <tr>
                        <th>时间</th>
                        <th>成员</th>
                        <th>分类</th>
                        <th>商户</th>
                        <th>支付方式</th>
                        <th>金额</th>
                        <th>备注</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td>@item.OccurredAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@item.MemberName</td>
                            <td>@item.CategoryName</td>
                            <td>@item.MerchantName</td>
                            <td>@item.PaymentMethod</td>
                            <td class="@(item.Kind == TransactionKind.Expense ? "expense" : "income")">
                                @((item.Kind == TransactionKind.Expense ? "-" : "+") + item.Amount.ToString("C"))
                            </td>
                            <td>@item.Note</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

@code {
    private string _selectedMonthText = $"{DateTime.Today:yyyy-MM}";
    private IReadOnlyList<TransactionListItem>? _items;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task OnMonthChanged(ChangeEventArgs args)
    {
        _selectedMonthText = args.Value?.ToString() ?? _selectedMonthText;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        var month = DateOnly.Parse($"{_selectedMonthText}-01");
        _items = await LedgerService.GetTransactionsAsync(month);
    }
}

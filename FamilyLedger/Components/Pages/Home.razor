@page "/"
@attribute [StreamRendering]
@inject LedgerService LedgerService

<PageTitle>家庭账本概览</PageTitle>

<section class="dashboard-grid">
    <div class="hero-card">
        <div>
            <p class="section-tag">MVP Focus</p>
            <h2>让家庭成员愿意记，而不是被迫记。</h2>
            <p class="hero-copy">第一版优先把“快速记一笔”和“截图转待确认账单”做顺，再逐步补齐统计、预算和自动化。</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-primary" href="quick-entry">现在记一笔</a>
            <a class="btn btn-outline-dark" href="capture-inbox">看截图收件箱</a>
        </div>
    </div>

    @if (_dashboard is null)
    {
        <div class="loading-card p-4">正在加载记账概览...</div>
    }
    else
    {
        <div class="stats-grid">
            <article class="stat-card warm">
                <span>本月支出</span>
                <strong>@_dashboard.MonthExpense.ToString("C")</strong>
                <small>家庭最常见的快速录入目标</small>
            </article>
            <article class="stat-card cool">
                <span>本月收入</span>
                <strong>@_dashboard.MonthIncome.ToString("C")</strong>
                <small>用于结余和月度总览</small>
            </article>
            <article class="stat-card neutral">
                <span>本月结余</span>
                <strong>@_dashboard.NetBalance.ToString("C")</strong>
                <small>收入减去支出的即时结果</small>
            </article>
            <article class="stat-card accent">
                <span>待确认截图</span>
                <strong>@_dashboard.PendingCaptureCount</strong>
                <small>快捷指令上传后在这里消化</small>
            </article>
        </div>

        <div class="content-grid">
            <section class="panel">
                <div class="panel-head">
                    <div>
                        <p class="section-tag">Recent</p>
                        <h3>最近账单</h3>
                    </div>
                    <a href="transactions">查看全部</a>
                </div>

                <div class="list-stack">
                    @foreach (var item in _dashboard.RecentTransactions)
                    {
                        <article class="transaction-row">
                            <div>
                                <strong>@item.CategoryName</strong>
                                <p>@item.MemberName · @item.MerchantName</p>
                            </div>
                            <div class="amount-block">
                                <strong class="@(item.Kind == TransactionKind.Expense ? "expense" : "income")">
                                    @((item.Kind == TransactionKind.Expense ? "-" : "+") + item.Amount.ToString("C"))
                                </strong>
                                <small>@item.OccurredAt.LocalDateTime.ToString("MM-dd HH:mm")</small>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="panel">
                <div class="panel-head">
                    <div>
                        <p class="section-tag">Shortcut</p>
                        <h3>截图识别闭环</h3>
                    </div>
                </div>

                <ol class="flow-list">
                    <li>iPhone 快捷指令获取最新截图或分享中的图片。</li>
                    <li>上传给 <code>POST /api/family-ledger/capture-drafts</code>。</li>
                    <li>后端生成待确认账单，保留金额、商户、时间建议。</li>
                    <li>在“截图收件箱”里一键转为正式支出。</li>
                </ol>
            </section>
        </div>
    }
</section>

@code {
    private DashboardSnapshot? _dashboard;

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await LedgerService.GetDashboardAsync();
    }
}

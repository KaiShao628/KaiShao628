@page "/capture-inbox"
@rendermode InteractiveServer
@inject LedgerService LedgerService

<PageTitle>截图收件箱</PageTitle>

<section class="capture-page">
    <div class="capture-layout">
        <section class="capture-flow">
            <p class="section-tag">Shortcut Workflow</p>
            <h2>iPhone 快捷指令接入建议</h2>
            <ol class="flow-list">
                <li>截图后通过辅助功能或分享面板触发快捷指令。</li>
                <li>快捷指令直接调用 <code>POST /api/family-ledger/capture-drafts</code>。</li>
                <li>先上传识别后的金额、商户、文本摘要；图片持久化可后续接入对象存储。</li>
                <li>在本页复核并一键转成正式支出。</li>
            </ol>
        </section>

        <section class="capture-list">
            <p class="section-tag">Inbox</p>
            <h2>待确认账单</h2>

            @if (_drafts is null)
            {
                <p>正在读取截图收件箱...</p>
            }
            else if (_drafts.Count == 0)
            {
                <p>当前没有待确认账单。</p>
            }
            else
            {
                @foreach (var draft in _drafts)
                {
                    <article class="capture-card">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <strong>@draft.MerchantName</strong>
                                <p class="mb-1 text-muted">@draft.Source</p>
                            </div>
                            <strong class="expense">@draft.SuggestedAmount?.ToString("C")</strong>
                        </div>

                        <div class="capture-meta">
                            <span>@draft.MemberName</span>
                            <span>@draft.CategoryName</span>
                            <span>@draft.CapturedAt.LocalDateTime.ToString("MM-dd HH:mm")</span>
                            <span>@draft.Status</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(draft.RecognizedText))
                        {
                            <p class="mt-3 mb-0 text-muted">@draft.RecognizedText</p>
                        }

                        @if (draft.Status == CaptureDraftStatus.Pending)
                        {
                            <div class="capture-actions">
                                <button class="btn btn-primary" @onclick="() => PromoteAsync(draft.Id)">转为正式支出</button>
                            </div>
                        }
                    </article>
                }
            }
        </section>
    </div>
</section>

@code {
    private IReadOnlyList<CaptureDraftListItem>? _drafts;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task PromoteAsync(string draftId)
    {
        await LedgerService.PromoteCaptureDraftAsync(draftId);
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _drafts = await LedgerService.GetCaptureDraftsAsync();
    }
}

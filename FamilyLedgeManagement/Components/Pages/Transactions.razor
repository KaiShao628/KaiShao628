@page "/transactions"
@attribute [TabItemOption(Text = "账单流水")]

<PageTitle>账单流水</PageTitle>

<div class="table-page">
    <div class="table-page-header">
        <div>
            <h3>账单流水</h3>
            <p>账单列表使用 Bootstrap Blazor Table 弹窗编辑模式，支持整页展示、行选中、工具栏新增编辑删除，以及行内快捷操作。</p>
        </div>
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <Alert Color="Color.Success" ShowBar="true" ShowBorder="true">@Message</Alert>
        }
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <Alert Color="Color.Danger" ShowBar="true" ShowBorder="true">@ErrorMessage</Alert>
        }
    </div>

    <Table TItem="TransactionListItemDto" @ref="@_transactionTable" IsFixedHeader="true" IsPagination="true" PageItemsSource="@Helpers.PageItemSource" FixedExtendButtonsColumn="true"
           SearchMode="SearchMode.Top" ShowSearchText="false" SearchDialogItemsPerRow="2" ShowLoading="true" ShowColumnList="true"
           IsMultipleSelect="true" IsBordered="true" IsStriped="true" ClickToSelect="true" IsKeepSelectedRows="true" SelectedRows="@SelectedRows"
           ShowSearch="true" ShowRefresh="true" ShowAdvancedSearch="false" AddModalTitle="新增账单" EditModalTitle="编辑账单"
           ShowToolbar="true" ShowAddButton="true" ShowEditButton="true" ShowDeleteButton="true" ShowToastAfterSaveOrDeleteModel="false"
           ShowDefaultButtons="true" ShowExtendButtons="true" ShowExtendEditButton="true" ShowExtendDeleteButton="true" OnResetSearchAsync="OnResetSearchAsync" AllowResizing="true"
           OnQueryAsync="@OnQueryAsync" OnAddAsync="@OnAddAsync" OnSaveAsync="@OnSaveAsync" OnDeleteAsync="@OnDeleteAsync">
        <ToolbarTemplate>
            <TableToolbarComponent>
                <Select DisplayText="月份" ShowLabel="true" Items="@SelectMonthItems" @bind-Value="SelectedMonthText" />
            </TableToolbarComponent>
        </ToolbarTemplate>
        <TableColumns>
            <TableColumn @bind-Field="@context.Id" Text="编号" Ignore="true" Readonly="true" />
            <TableColumn @bind-Field="@context.OccurredAt" Text="时间" FormatString="yyyy-MM-dd HH:mm" Sortable="true" />
            <TableColumn @bind-Field="@context.Kind" Text="类型" />
            <TableColumn @bind-Field="@context.MemberId" Text="成员" Lookup="@MemberLookup" Searchable="true" />
            <TableColumn @bind-Field="@context.CategoryId" Text="分类" Lookup="@CategoryLookup" Searchable="true" />
            <TableColumn @bind-Field="@context.MerchantName" Text="账单名称" Searchable="true" />
            <TableColumn @bind-Field="@context.PaymentMethod" Text="支付方式" Lookup="@PaymentMethodLookup" Searchable="true" />
            <TableColumn @bind-Field="@context.Amount" Text="金额" FormatString="F2" Sortable="true" />
            <TableColumn @bind-Field="@context.Note" Text="备注" />
        </TableColumns>
    </Table>
</div>




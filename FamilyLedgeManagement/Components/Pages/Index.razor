@page "/"
@attribute [TabItemOption(Text = "概览", Closable = false)]

<PageTitle>家庭账本概览</PageTitle>

<div class="page-dashboard">
    <Card HeaderText="项目目标" IsShadow="true">
        <BodyTemplate>
            <div class="dashboard-intro">
                <div>
                    <h2>让家庭成员愿意记，而不是被迫记。</h2>
                    <p>第一版优先把“快速记一笔”和“截图记账”做顺，再逐步补齐统计、预算和自动化。</p>
                </div>
                <div class="dashboard-links">
                    <LinkButton Text="现在记一笔" Url="/quick-entry" Color="Color.Primary" />
                    <LinkButton Text="截图记账" Url="/capture-inbox" Color="Color.Info" IsOutline="true" />
                </div>
            </div>
        </BodyTemplate>
    </Card>

    <div class="dashboard-stats">
        <Card HeaderText="本月支出" Color="Color.Danger" IsShadow="true">
            <BodyTemplate>
                <Display TValue="decimal" Value="@Dashboard.MonthExpense" FormatString="C" ShowLabel="false" />
                <p>家庭最常见的快速录入目标</p>
            </BodyTemplate>
        </Card>
        <Card HeaderText="本月收入" Color="Color.Success" IsShadow="true">
            <BodyTemplate>
                <Display TValue="decimal" Value="@Dashboard.MonthIncome" FormatString="C" ShowLabel="false" />
                <p>用于结余和月度总览</p>
            </BodyTemplate>
        </Card>
        <Card HeaderText="本月结余" Color="Color.Info" IsShadow="true">
            <BodyTemplate>
                <Display TValue="decimal" Value="@Dashboard.NetBalance" FormatString="C" ShowLabel="false" />
                <p>收入减去支出的即时结果</p>
            </BodyTemplate>
        </Card>
        <Card HeaderText="截图记账" Color="Color.Warning" IsShadow="true">
            <BodyTemplate>
                <Display TValue="int" Value="@Dashboard.PendingCaptureCount" ShowLabel="false" />
                <p>识别截图后直接写入正式账单</p>
            </BodyTemplate>
        </Card>
    </div>

    <div class="table-page">
        <div class="table-page-header">
            <div>
                <h3>最近账单</h3>
                <p>最近账单使用 Bootstrap Blazor Table 弹窗编辑模式，支持行选中、工具栏新增编辑删除，以及行内快捷操作。</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <Alert Color="Color.Success" ShowBar="true" ShowBorder="true">@Message</Alert>
            }
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <Alert Color="Color.Danger" ShowBar="true" ShowBorder="true">@ErrorMessage</Alert>
            }
        </div>

        <Table TItem="TransactionEditorDto"
               Items="@RecentItems"
               ShowToolbar="true"
               ShowSearch="true"
           ShowPagination="true"
           PageItems="59"
           PageItemsSource="@DefaultPageItemsSource"
               ShowAddButton="true"
               ShowEditButton="true"
               ShowDeleteButton="true"
           ShowDefaultButtons="true"
           ShowExtendButtons="true"
               ShowExtendEditButton="true"
               ShowExtendDeleteButton="true"
               IsBordered="true"
               IsStriped="true"
               ClickToSelect="true"
               IsMultipleSelect="true"
               IsKeepSelectedRows="true"
               SelectedRows="@SelectedRows"
               SelectedRowsChanged="@OnSelectedRowsChanged"
               EditMode="EditMode.Popup"
               AddModalTitle="新增账单"
               EditModalTitle="编辑账单"
               OnAddAsync="@OnAddAsync"
               OnSaveAsync="@OnSaveAsync"
               OnDeleteAsync="@OnDeleteAsync">
            <TableColumns>
                <TableColumn @bind-Field="@context.Id" Text="编号" Ignore="true" Readonly="true" />
                <TableColumn @bind-Field="@context.OccurredAt" Text="时间" FormatString="MM-dd HH:mm" Sortable="true" />
                <TableColumn @bind-Field="@context.Kind" Text="类型" />
                <TableColumn @bind-Field="@context.MemberId" Text="成员" Lookup="@MemberLookup" Searchable="true" />
                <TableColumn @bind-Field="@context.CategoryId" Text="分类" Lookup="@CategoryLookup" Searchable="true" />
                <TableColumn @bind-Field="@context.MerchantName" Text="账单名称" Searchable="true" />
                <TableColumn @bind-Field="@context.PaymentMethod" Text="支付方式" Lookup="@PaymentMethodLookup" Searchable="true" />
                <TableColumn @bind-Field="@context.Amount" Text="金额" FormatString="C" Sortable="true" />
                <TableColumn @bind-Field="@context.Note" Text="备注" />
            </TableColumns>
        </Table>
    </div>

    <div class="dashboard-grid-two">
        <Card HeaderText="截图识别闭环" IsShadow="true">
            <BodyTemplate>
                <Alert Color="Color.Light" ShowBar="true" ShowBorder="true">iPhone 快捷指令可把截图上传给接口，系统识别金额、时间、商品和支付方式后直接保存为正式账单。</Alert>
                <ol class="flow-list">
                    <li>快捷指令获取最新截图或分享中的图片。</li>
                    <li>上传给 <code>POST /api/family-ledger/capture-drafts/upload</code>。</li>
                    <li>后端识别金额、时间、商品、支付方式等核心字段。</li>
                    <li>识别完成后直接生成正式账单，可在账单流水中维护。</li>
                </ol>
            </BodyTemplate>
        </Card>
    </div>
</div>



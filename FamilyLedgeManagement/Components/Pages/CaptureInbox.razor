@page "/capture-inbox"
@attribute [TabItemOption(Text = "截图记账")]

<PageTitle>截图记账</PageTitle>

@if (Context is null)
{
    <Alert Color="Color.Info" ShowBar="true" ShowBorder="true">正在加载上传上下文...</Alert>
}
else
{
    <div class="capture-layout">
        <Card HeaderText="图片上传入口" IsShadow="true">
            <BodyTemplate>
                <Alert Color="Color.Info" ShowBorder="true" ShowBar="true">现在的流程是：选择截图后自动 OCR 识别金额、时间、商品和支付方式，再点击按钮直接保存到账单流水。</Alert>
                <Alert Color="Color.Secondary" ShowBorder="true" ShowBar="true">当前页面只保留 OCR 识别和正式入账，不再生成草稿或经过收件箱确认。</Alert>

                <ValidateForm Model="@UploadRequest" OnValidSubmit="SaveUploadAsync">
                    <div class="form-grid">
                        <div>
                            <label class="form-label">家庭成员</label>
                            <Select TValue="string" @bind-Value="UploadRequest.MemberId">
                                @foreach (var member in Context.Members)
                                {
                                    <SelectOption Value="@member.Id" Text="@member.Name" />
                                }
                            </Select>
                        </div>
                        <div>
                            <label class="form-label">建议分类</label>
                            <Select TValue="string" @bind-Value="UploadRequest.SuggestedCategoryId">
                                @foreach (var category in ExpenseCategories)
                                {
                                    <SelectOption Value="@category.Id" Text="@category.Name" />
                                }
                            </Select>
                        </div>
                        <div>
                            <label class="form-label">建议金额</label>
                            <BootstrapInputNumber TValue="decimal?" @bind-Value="UploadRequest.SuggestedAmount" ShowButton="true" Step="1" />
                        </div>
                        <div>
                            <label class="form-label">商户/场景</label>
                            <BootstrapInput TValue="string" @bind-Value="UploadRequest.MerchantName" />
                        </div>
                        <div>
                            <label class="form-label">来源</label>
                            <BootstrapInput TValue="string" @bind-Value="UploadRequest.Source" />
                        </div>
                        <div>
                            <label class="form-label">截图时间</label>
                            <DateTimePicker TValue="DateTimeOffset?" @bind-Value="UploadRequest.CapturedAt" />
                        </div>
                        <div class="full">
                            <label class="form-label">识别文本/备注</label>
                            <Textarea @bind-Value="UploadRequest.RecognizedText" Rows="3" />
                        </div>
                        <div class="full" @key="UploadKey">
                            <label class="form-label">截图图片</label>
                            <InputUpload TValue="string" IsMultiple="false" Accept="image/*,.heic" ShowDeleteButton="true" BrowserButtonText="选择截图" PlaceHolder="选择支付截图、订单截图或分享的图片" OnChange="OnUploadChanged" />
                        </div>
                    </div>

                    @if (SelectedUploadFile is not null)
                    {
                        <div class="capture-preview-panel">
                            <div class="capture-preview-meta">
                                <span>已选文件：@(SelectedUploadFile.OriginFileName ?? SelectedUploadFile.FileName)</span>
                                <span>大小：@((SelectedUploadFile.Size / 1024d).ToString("F1")) KB</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(SelectedUploadFile.PrevUrl))
                            {
                                <img class="capture-preview-image" src="@SelectedUploadFile.PrevUrl" alt="截图预览" />
                            }
                        </div>
                    }

                    @if (RecognitionPreview is not null)
                    {
                        <Alert Color="Color.Light" ShowBorder="true" ShowBar="true">
                            <div>OCR 金额：@(RecognitionPreview.SuggestedAmount?.ToString("F2") ?? "未识别")</div>
                            <div>OCR 时间：@(RecognitionPreview.OccurredAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "未识别")</div>
                            <div>OCR 商品：@(string.IsNullOrWhiteSpace(RecognitionPreview.ProductName) ? "未识别" : RecognitionPreview.ProductName)</div>
                            <div>OCR 支付方式：@(string.IsNullOrWhiteSpace(RecognitionPreview.PaymentMethod) ? "未识别" : RecognitionPreview.PaymentMethod)</div>
                        </Alert>
                    }

                    <div class="action-row">
                        <Button Text="识别并立即保存" Color="Color.Primary" ButtonType="ButtonType.Submit" />
                    </div>
                </ValidateForm>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <Alert Color="Color.Success" ShowBar="true" ShowBorder="true">@Message</Alert>
                }

                @if (LatestSavedTransaction is not null)
                {
                    <Alert Color="Color.Success" ShowBorder="true" ShowBar="true">
                        <div>已保存金额：@LatestSavedTransaction.Amount.ToString("F2")</div>
                        <div>账单名称：@LatestSavedTransaction.MerchantName</div>
                        <div>支付方式：@LatestSavedTransaction.PaymentMethod</div>
                        <div>记账时间：@LatestSavedTransaction.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </Alert>
                }

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <Alert Color="Color.Danger" ShowBar="true" ShowBorder="true">@ErrorMessage</Alert>
                }
            </BodyTemplate>
        </Card>

        <Card HeaderText="iPhone / 快捷指令接入" IsShadow="true">
            <BodyTemplate>
                <Alert Color="Color.Light" ShowBorder="true" ShowBar="true">推荐链路：截图或分享图片 -> 快捷指令 -> <code>POST /api/family-ledger/capture/upload</code> -> OCR 识别 -> 直接保存正式账单。</Alert>
                <ol class="flow-list">
                    <li>快捷指令通过 <code>multipart/form-data</code> 上传图片字段 <code>file</code>。</li>
                    <li>同时可提交 <code>memberId</code>、<code>suggestedCategoryId</code>、<code>suggestedAmount</code>、<code>merchantName</code>。</li>
                    <li>接口会先 OCR 识别，再直接保存为正式支出记录。</li>
                    <li>后续可以继续增强分类建议和字段纠错。</li>
                </ol>
            </BodyTemplate>
        </Card>
    </div>
}
